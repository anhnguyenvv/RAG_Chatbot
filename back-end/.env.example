GOOGLE_API_KEY=
QDRANT_URL=
QDRANT_API_KEY=
HUGGINGFACE_API_KEY=

QDRANT_COLLECTION_NAME=ITUS_mpnet_1000v1
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
GENERATE_MODEL_NAME=gemini
CHAT_HISTORY_DB_PATH=./data/chat_history.db
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
ENABLE_RERANKER=true
ENABLE_AGENTIC_PIPELINE=false
ROUTER_CONFIDENCE_THRESHOLD=0.55
RETRIEVAL_DENSE_TOP_K=20
RETRIEVAL_SPARSE_TOP_K=20
RETRIEVAL_WEB_TOP_K=5
RERANK_MODEL_NAME=
RERANK_CANDIDATES=40
MAX_CONTEXT_TOKENS=2800
CRITIC_ENABLED=true
OFFICIAL_SITE_ALLOWLIST=fit.hcmus.edu.vn

AGENT_MAX_ITERATIONS=5
MEMORY_MAX_RECENT_TURNS=3
MEMORY_SESSION_TTL=1800
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=rag_chatbot

# Rate Limiting (format: "count/period" — e.g. "10/minute", "100/hour")
RATE_LIMIT_RAG=10/minute
RATE_LIMIT_DEFAULT=30/minute
RATE_LIMIT_ADMIN=5/minute

# Retrieval KV cache (in-memory TTL)
RETRIEVAL_CACHE_ENABLED=true
RETRIEVAL_CACHE_TTL=600
RETRIEVAL_CACHE_MAXSIZE=500

# Admin endpoints (leave empty to disable /admin/* routes)
ADMIN_API_KEY=

NGROK_TOKEN=
NGROK_STATIC_DOMAIN=

# --- Alternative LLM endpoints (OpenAI-compatible) ---
# Ollama Cloud — multimodal, Vietnamese
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_BASE_URL=https://ollama.com
OLLAMA_CLOUD_MODEL=deepseek-v3.2

# ClipProxy — VPS nội bộ, hỗ trợ GPT-5 / Claude / Gemini / Ollama qua 1 key
CLIPPROXY_API_KEY=
CLIPPROXY_BASE_URL=http://47.84.103.226/v1
CLIPPROXY_MODEL=gpt-4o
