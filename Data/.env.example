QDRANT_URL=
QDRANT_API_KEY=
QDRANT_FORCE_RECREATE=true
HUGGINGFACE_API_KEY=
GEMINI_API_KEY=
QDRANT_COLLECTION_NAME=ITUS_mpnet_1000v1
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
PIPELINE_SOURCE_DIR=./Database
CHUNK_STRATEGY=outline
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- OCR backends ---
# OpenAI (cho --model gpt4o)
OPENAI_API_KEY=

# Ollama Cloud (cho --model ollama)
# Lấy key tại https://ollama.com/settings/keys
# Model phải là multimodal: gemma3:27b, llama4:scout, llama4:maverick
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_BASE_URL=https://ollama.com
OLLAMA_CLOUD_OCR_MODEL=gemma3:27b

# ClipProxy (cho --model clipproxy) — VPS nội bộ, OpenAI-compatible
# Hỗ trợ GPT-5 / Claude / Gemini / Ollama qua 1 key
CLIPPROXY_API_KEY=
CLIPPROXY_BASE_URL=http://47.84.103.226/v1
CLIPPROXY_OCR_MODEL=gpt-4o
